# Amazon Now Snap - Environment Variables Example
# Copy this file to .env for local development
# NEVER commit .env to git

# Deployment Mode Feature Flags
ENABLE_OPENSEARCH=false          # false = DynamoSearchAdapter | true = OpenSearchAdapter
ENABLE_REDIS=false               # false = DynamoCacheAdapter | true = RedisCacheAdapter
ENABLE_PERSONALIZE=false         # false = RuleBasedRecommendationAdapter | true = PersonalizeAdapter
ENABLE_BEDROCK=false             # false = KeywordIntentAdapter | true = BedrockIntentAdapter
ENABLE_REKOGNITION=false         # false = BarcodeVisionAdapter | true = RekognitionAdapter
ENABLE_TRANSCRIBE=false          # false = BrowserSpeechAdapter | true = TranscribeAdapter

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id-here
AWS_PROFILE=default

# Environment
NODE_ENV=development
STAGE=dev

# API Configuration
API_BASE_URL=http://localhost:3000
API_VERSION=v1

# DynamoDB Local (for development)
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_PREFIX=Dev-Snap

# Redis Local (for development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenSearch Local (for development)
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=snap

# Cognito (replace with actual values)
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_CLIENT_ID=your-client-id-here
COGNITO_REGION=ap-south-1

# S3 Buckets
S3_PHOTO_UPLOADS_BUCKET=snap-photo-uploads-dev
S3_PRODUCT_IMAGES_BUCKET=snap-product-images-dev
S3_ML_TRAINING_BUCKET=snap-ml-training-dev

# SQS Queues
SQS_PHOTO_PROCESS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/xxxx/snap-photo-process-queue-dev
SQS_ORDER_EVENTS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/xxxx/snap-order-events-queue-dev
SQS_NOTIFICATION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/xxxx/snap-notification-queue-dev

# SNS Topics
SNS_PUSH_IOS_ARN=arn:aws:sns:ap-south-1:xxxx:snap-push-ios-dev
SNS_PUSH_ANDROID_ARN=arn:aws:sns:ap-south-1:xxxx:snap-push-android-dev

# Bedrock (Production Mode)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=ap-south-1

# Personalize (Production Mode)
PERSONALIZE_CAMPAIGN_ARN=arn:aws:personalize:ap-south-1:xxxx:campaign/snap-user-personalization-campaign

# Logging
LOG_LEVEL=info              # debug | info | warn | error
LOG_FORMAT=json             # json | pretty

# Feature-specific Configuration
SMART_CART_TTL_SECONDS=21600           # 6 hours
INVENTORY_CACHE_TTL_SECONDS=30         # 30 seconds
ETA_CACHE_TTL_SECONDS=60               # 60 seconds
TRENDING_CACHE_TTL_SECONDS=900         # 15 minutes
PRODUCT_CACHE_TTL_SECONDS=3600         # 1 hour
BARCODE_CACHE_TTL_SECONDS=3600         # 1 hour
RESERVATION_TTL_SECONDS=90             # 90 seconds soft-reserve

# Smart Cart Tiers
SMART_CART_TIER_1_MAX_ORDERS=4         # 0-4 orders = trending
SMART_CART_TIER_2_MAX_ORDERS=19        # 5-19 orders = hybrid
SMART_CART_TIER_3_MIN_ORDERS=20        # 20+ orders = full personalize

# AI Confidence Thresholds
AI_CONFIDENCE_SINGLE_THRESHOLD=0.75    # >= 0.75 = single result
AI_CONFIDENCE_ALTERNATIVES_THRESHOLD=0.50  # 0.50-0.74 = with alternatives
AI_CONFIDENCE_MIN_THRESHOLD=0.50       # < 0.50 = graceful failure

# Search Configuration
SEARCH_MAX_RESULTS=20
SEARCH_MAX_TOKENS=5                    # DynamoSearchAdapter token limit

# Performance
LAMBDA_TIMEOUT_STANDARD=10000          # 10 seconds
LAMBDA_TIMEOUT_AI=30000                # 30 seconds for AI operations
LAMBDA_MEMORY_STANDARD=256             # 256 MB
LAMBDA_MEMORY_AI=512                   # 512 MB for AI operations

# Testing
TEST_USER_ID=test_user_01J2K3L4M5N6P7Q8
TEST_PINCODE=110001
TEST_PRODUCT_ID=prod_001

# Payment (Mock in development)
PAYMENT_PROVIDER=amazon_pay
PAYMENT_MOCK=true

# Monitoring
ENABLE_XRAY=true
ENABLE_METRICS=true
ENABLE_DETAILED_LOGGING=false

# Security
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/${COGNITO_USER_POOL_ID}

# Dark Store Configuration (for ETA calculation)
DEFAULT_AVG_PICKUP_MINUTES=5
DEFAULT_LAST_MILE_MINUTES=8

# Notification Configuration
NOTIFICATION_QUIET_START=22:00
NOTIFICATION_QUIET_END=08:00

# Rate Limiting
API_RATE_LIMIT_PER_SECOND=10000
API_BURST_LIMIT=5000

# CDK Configuration
CDK_DEFAULT_ACCOUNT=your-account-id-here
CDK_DEFAULT_REGION=ap-south-1
CDK_QUALIFIER=amazonnowsnap

# Local Development
LOCAL_DEVELOPMENT=true
SKIP_AUTH_IN_DEV=false                 # Set to true to skip JWT validation in local dev
