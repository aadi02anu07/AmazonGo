{
  "name": "amazon-now-snap",
  "version": "1.2.0",
  "description": "Amazon Now Snap - Get everything on the Go",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "cdk": "cdk",
    "cdk:deploy": "cdk deploy --all",
    "cdk:deploy:dev": "cdk deploy --all --context env=dev",
    "cdk:deploy:staging": "cdk deploy --all --context env=staging",
    "cdk:deploy:prod": "cdk deploy --all --context env=prod",
    "cdk:diff": "cdk diff",
    "cdk:synth": "cdk synth",
    "cdk:bootstrap": "cdk bootstrap",
    "local:dynamodb": "docker-compose up dynamodb-local",
    "local:redis": "docker-compose up redis-local",
    "local:opensearch": "docker-compose up opensearch-local",
    "local:all": "docker-compose up",
    "local:down": "docker-compose down",
    "serverless:offline": "serverless offline start --stage dev",
    "seed:dev": "ts-node scripts/seed-dev-data.ts",
    "prepare": "husky install",
    "precommit": "lint-staged"
  },
  "keywords": [
    "quick-commerce",
    "amazon",
    "serverless",
    "aws",
    "lambda",
    "dynamodb",
    "cdk",
    "typescript"
  ],
  "author": "Amazon Now Snap Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.540.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.540.0",
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/client-eventbridge": "^3.540.0",
    "@aws-sdk/client-personalize": "^3.540.0",
    "@aws-sdk/client-personalize-runtime": "^3.540.0",
    "@aws-sdk/client-rekognition": "^3.540.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/client-secrets-manager": "^3.540.0",
    "@aws-sdk/client-sns": "^3.540.0",
    "@aws-sdk/client-sqs": "^3.540.0",
    "@aws-sdk/client-ssm": "^3.540.0",
    "@aws-sdk/client-transcribe-streaming": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@opensearch-project/opensearch": "^2.6.0",
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.136",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "aws-cdk": "^2.130.0",
    "aws-sdk-client-mock": "^4.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.3.3",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
